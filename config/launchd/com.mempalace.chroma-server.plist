<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mempalace.chroma-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>__PIPX_PYTHON__</string>
        <string>__CHROMA_BIN__</string>
        <string>run</string>
        <string>--path</string>
        <string>__MEMPALACE_HOME__/palace</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8001</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__MEMPALACE_HOME__</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__MEMPALACE_HOME__/chroma-server.log</string>

    <key>StandardErrorPath</key>
    <string>__MEMPALACE_HOME__/chroma-server.log</string>
</dict>
</plist>
